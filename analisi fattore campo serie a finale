    "def valuta_modello(model, X_train, X_test, y_train, y_test, nome, scaled=False):\n",
    "    \"\"\"Calcola metriche di valutazione per un modello.\"\"\"\n",
    "    \n",
    "    # Predizioni\n",
    "    y_train_pred = model.predict(X_train)\n",
    "    y_test_pred = model.predict(X_test)\n",
    "    \n",
    "    # Metriche\n",
    "    mae_train = mean_absolute_error(y_train, y_train_pred)\n",
    "    mae_test = mean_absolute_error(y_test, y_test_pred)\n",
    "    \n",
    "    rmse_train = np.sqrt(mean_squared_error(y_train, y_train_pred))\n",
    "    rmse_test = np.sqrt(mean_squared_error(y_test, y_test_pred))\n",
    "    \n",
    "    r2_train = r2_score(y_train, y_train_pred)\n",
    "    r2_test = r2_score(y_test, y_test_pred)\n",
    "    \n",
    "    # Cross-validation\n",
    "    cv_scores = cross_val_score(model, X_train if not scaled else X_train_scaled, \n",
    "                                y_train, cv=5, scoring='r2')\n",
    "    \n",
    "    risultati = {\n",
    "        'Model': nome,\n",
