unts()\n","cluster_dominante = cluster_sizes.idxmax()\n","cluster_pct = cluster_sizes.max() / len(df_cl) * 100\n","\n","# Calculate offensive efficiency for each team at home\n","# This is defined as goals scored at home per shot on target at home\n","efficienza_squadre = df.groupby('Squadra_Casa').apply(\n","    lambda x: x['Gol_Casa'].sum() / x['Tiri_Porta_Casa'].sum()\n","    if x['Tiri_Porta_Casa'].sum() > 0 else 0\n",").rename('Efficienza_Offensiva_Casa')\n","\n","efficienza_media = efficienza_squadre.mean()\n","squadra_top = efficienza_squadre.idxmax()\n","\n","# Costruisco la tabella\n","conclusioni = pd.DataFrame({\n","    'Tecnica': [\n","        'Regressione multipla',\n","        'Classificazione (Random Forest)',\n","        'Clustering (KMeans)',\n","        'Efficienza offensiva'\n","    ],\n","    'Cosa misura': [\n","        'Gol previsti per la squadra di casa',\n","        'Risultato della partita (V/P/S)',\n","        'Tipo di partita per intensità',\n","        'Gol per tiro in porta in casa'\n","    ],\n","    'Risultato chiave': [\n","        f'R² = {r2_regressione:.2f} — tiri in porta il predittore più forte',\n","        f'Accuracy = {accuracy_classificazione:.1%} — vittoria casa la classe più riconosciuta',\n","        f'Cluster prevalente: {cluster_dominante} ({cluster_pct:.0f}% partite)',\n","        f'Squadra più efficiente: {squadra_top} ({efficienza_squadre.max():.2f})'\n","    ],\n","    'Risposta sul fattore campo': [\n","        'I tiri in porta di casa pesano più di quelli in trasferta',\n","        'Il modello predice meglio le vittorie casalinghe',\n","        'Le partite a dominio casalingo formano un cluster distinto',\n","        'Giocare in casa migliora la conversione dei tiri'\n","    ]\n","})\n","\n","print(\"=\" * 90)\n","print(\"RIEPILOGO — FATTORE CAMPO IN SERIE A: COSA CI DICE IL MACHINE LEARNING\")\n","print(\"=\" * 90)\n","display(conclusioni.style\n","    .set_properties(**{'text-align': 'left', 'font-size': '13px'})