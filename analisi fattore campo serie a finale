    "    'Como': 'COMO',\n",
    "    'Parma': 'PARMA'\n",
    "}\n",
    "\n",
    "# Funzione di normalizzazione\n",
    "def normalizza_squadra(nome):\n",
    "    \"\"\"\n",
    "    Normalizza il nome della squadra:\n",
    "    - Rimuove spazi extra\n",
    "    - Converte in maiuscolo\n",
