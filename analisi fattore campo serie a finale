    "    \"\"\"\n",
    "    nome = str(nome).strip()  # Rimuove spazi\n",
    "\n",
    "    # Se esiste un mapping, usalo\n",
    "    if nome in mapping_squadre:\n",
    "        return mapping_squadre[nome]\n",
    "\n",
    "    # Altrimenti converti solo in maiuscolo\n",
    "    return nome.upper()\n",
    "\n",
