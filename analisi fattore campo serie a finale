   "source": [
    "# Dizionario di mapping:  → nome completo in maiuscolo per maggiore chia\n",
    "mapping_squadre = {\n",
    "    'Atalanta': 'ATALANTA',\n",
    "    'Bologna': 'BOLOGNA',\n",
    "    'Cagliari': 'CAGLIARI',\n",
    "    'Empoli': 'EMPOLI',\n",
    "    'Fiorentina': 'FIORENTINA',\n",
    "    'Genoa': 'GENOA',\n",
    "    'Inter': 'INTER',\n",
    "    'Juventus': 'JUVENTUS',\n",
    "    'Lazio': 'LAZIO',\n",
    "    'Lecce': 'LECCE',\n",
    "    'Milan': 'MILAN',\n",
    "    'Napoli': 'NAPOLI',\n",
    "    'Roma': 'ROMA',\n",
    "    'Salernitana': 'SALERNITANA',\n",
    "    'Sampdoria': 'SAMPDORIA',\n",
    "    'Sassuolo': 'SASSUOLO',\n",
    "    'Spezia': 'SPEZIA',\n",
