    "        'MAE_Test': mae_test,\n",
    "        'RMSE_Train': rmse_train,\n",
    "        'RMSE_Test': rmse_test,\n",
    "        'R2_Train': r2_train,\n",
    "        'R2_Test': r2_test,\n",
    "        'CV_Mean': cv_scores.mean(),\n",
    "        'CV_Std': cv_scores.std(),\n",
    "        'y_pred_test': y_test_pred\n",
    "    }\n",
    "    \n",
    "    return risultati, y_test_pred\n",
